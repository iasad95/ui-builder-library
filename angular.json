{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "cli": {
    "analytics": "f43a2ad4-c985-467c-82db-7b321a2b1163",
    "schematicCollections": ["@angular-eslint/schematics"]
  },
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "ui-builder-component-lib": {
      "projectType": "library",
      "root": "projects/ui-builder-component-lib",
      "sourceRoot": "projects/ui-builder-component-lib/src",
      "prefix": "lib",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:ng-packagr",
          "options": {
            "project": "projects/ui-builder-component-lib/ng-package.json"
          },
          "configurations": {
            "production": {
              "tsConfig": "projects/ui-builder-component-lib/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "projects/ui-builder-component-lib/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        },
        "lint": {
          "builder": "@angular-eslint/builder:lint",
          "options": {
            "lintFilePatterns": ["projects/ui-builder-component-lib/**/*.ts", "projects/ui-builder-component-lib/**/*.html"]
          }
        }
      }
    },
    "ui-builder-component-lib-test": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": {
          "style": "scss"
        },
        "@schematics/angular:application": {
          "strict": true
        }
      },
      "root": "projects/ui-builder-component-lib-test",
      "sourceRoot": "projects/ui-builder-component-lib-test/src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:browser",
          "options": {
            "outputPath": "www",
            "index": "projects/ui-builder-component-lib-test/src/index.html",
            "main": "projects/ui-builder-component-lib-test/src/main.ts",
            "polyfills": "projects/ui-builder-component-lib-test/src/polyfills.ts",
            "tsConfig": "projects/ui-builder-component-lib-test/tsconfig.app.json",
            "inlineStyleLanguage": "scss",
            "assets": [
              "projects/ui-builder-component-lib-test/src/favicon.ico",
              "projects/ui-builder-component-lib-test/src/assets",
              {
                "glob": "**/*",
                "input": "dist/ui-builder-component-lib/src/assets",
                "output": "/assets/"
              }
            ],
            "styles": [
              "node_modules/primeng/resources/themes/md-dark-indigo/theme.css",
              "node_modules/primeng/resources/primeng.min.css",
              "node_modules/primeicons/primeicons.css",
              "node_modules/jsoneditor/dist/jsoneditor.min.css",
              "node_modules/quill/dist/quill.snow.css",
              "projects/ui-builder-component-lib-test/src/assets/icons/styles.css",
              "projects/ui-builder-component-lib-test/src/styles/styles.scss"
            ],
            "scripts": []
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "6mb",
                  "maximumError": "8mb"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "4kb",
                  "maximumError": "500kb"
                }
              ],
              "fileReplacements": [
                {
                  "replace": "projects/ui-builder-component-lib-test/src/environments/environment.ts",
                  "with": "projects/ui-builder-component-lib-test/src/environments/environment.prod.ts"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "buildOptimizer": false,
              "optimization": false,
              "vendorChunk": true,
              "extractLicenses": false,
              "sourceMap": true,
              "namedChunks": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "ui-builder-component-lib-test:build:production"
            },
            "development": {
              "buildTarget": "ui-builder-component-lib-test:build:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "extract-i18n": {
          "builder": "@angular-devkit/build-angular:extract-i18n",
          "options": {
            "buildTarget": "ui-builder-component-lib-test:build"
          }
        },
        "lint": {
          "builder": "@angular-eslint/builder:lint",
          "options": {
            "lintFilePatterns": ["projects/ui-builder-component-lib-test/**/*.ts", "projects/ui-builder-component-lib-test/**/*.html"]
          }
        }
      }
    }
  }
}
