{
  "name": "my-workspace",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --port 4400",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "lint": "ng lint ui-builder-component-lib",
    "test:lib": "npx jest --config=jest.config.js --detect-open-handles --silent",
    "clear_jest": "npx jest --clearCache",
    "build_lib": "ng build ui-builder-component-lib --configuration production",
    "build_lib:watch": "ng build ui-builder-component-lib --watch",
    "npm_pack": "cd dist/ui-builder-component-lib && npm pack",
    "npm_pub": "cd dist/ui-builder-component-lib && npm publish",
    "package": "npm run build_lib && npm run npm_pack",
    "bump_version": "node scripts/increment-version.js -v patch",
    "bump": "cd projects/ui-builder-component-lib && npm version patch",
    "husky:prepare": "husky install",
    "prepare": "is-ci || npm run husky:prepare",
    "format": "npx prettier --write ."
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^17.3.12",
    "@angular/cdk": "^17.3.10",
    "@angular/common": "^17.3.12",
    "@angular/compiler": "^17.3.12",
    "@angular/core": "^17.3.12",
    "@angular/forms": "^17.3.12",
    "@angular/google-maps": "^17.3.10",
    "@angular/localize": "^17.3.12",
    "@angular/material": "^17.3.10",
    "@angular/material-moment-adapter": "^17.3.10",
    "@angular/platform-browser": "^17.3.12",
    "@angular/platform-browser-dynamic": "^17.3.12",
    "@angular/router": "^17.3.12",
    "@googlemaps/js-api-loader": "^1.16.8",
    "@ionic/angular": "^8.2.6",
    "@ngx-translate/core": "^15.0.0",
    "@ngx-translate/http-loader": "^8.0.0",
    "ang-jsoneditor": "^3.1.1",
    "date-fns": "^2.30.0",
    "emoji-picker-element": "^1.22.1",
    "eslint-config-prettier": "^9.1.0",
    "google-libphonenumber": "^3.2.35",
    "inputmask": "^5.0.8",
    "jsoneditor": "^9.10.5",
    "lodash": "^4.17.21",
    "moment": "^2.29.4",
    "ng-otp-input": "^1.9.3",
    "ngx-bootstrap": "^12.0.0",
    "ngx-highlightjs": "^12.0.0",
    "ngx-image-compress": "^15.1.6",
    "ngx-image-cropper": "^7.1.2",
    "ngx-mask": "^17.1.8",
    "ngx-popperjs": "^17.0.0",
    "ngx-quill": "^25.3.2",
    "primeicons": "^6.0.1",
    "primeng": "^17.18.2",
    "rxjs": "^7.8.1",
    "uuid": "^9.0.1",
    "ws": "^8.18.0",
    "zone.js": "~0.14.8"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^17.0.5",
    "@angular-eslint/builder": "^17.1.1",
    "@angular-eslint/eslint-plugin": "^17.1.1",
    "@angular-eslint/eslint-plugin-template": "^17.1.1",
    "@angular-eslint/schematics": "^17.1.1",
    "@angular-eslint/template-parser": "^17.1.1",
    "@angular/cli": "^17.0.5",
    "@angular/compiler-cli": "^17.0.6",
    "@angular/language-service": "^17.0.6",
    "@babel/core": "^7.23.5",
    "@babel/preset-env": "^7.23.5",
    "@ionic/angular-toolkit": "^10.0.0",
    "@types/google-libphonenumber": "^7.4.30",
    "@types/inputmask": "^5.0.7",
    "@types/jest": "^29.5.11",
    "@typescript-eslint/eslint-plugin": "6.13.2",
    "@typescript-eslint/parser": "6.13.2",
    "babel-loader": "^9.1.3",
    "eslint": "^8.55.0",
    "eslint-config-google": "^0.14.0",
    "eslint-plugin-import": "^2.29.0",
    "eslint-plugin-jsdoc": "^46.9.0",
    "eslint-plugin-prefer-arrow": "^1.2.3",
    "eslint-plugin-prettier": "^5.0.1",
    "husky": "^9.0.11",
    "is-ci": "^3.0.1",
    "jest": "^29.7.0",
    "jest-preset-angular": "^13.1.4",
    "lint-staged": "^15.2.7",
    "ng-packagr": "^17.0.2",
    "prettier": "^3.1.0",
    "typescript": "~5.2.0",
    "webpack": "^5.89.0"
  },
  "lint-staged": {
    "projects/**/*.{ts,html}": [
      "git add .",
      "npx eslint"
    ]
  }
}
